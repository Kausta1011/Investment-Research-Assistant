# Copy this file to .env and fill in your keys.
# Only ONE LLM provider key is required.

# ─── Anthropic (default) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx

# ─── OpenAI (optional fallback) ────────────────────────────────────────
OPENAI_API_KEY=sk-xxx

# ─── Google Gemini (RECOMMENDED for free tier) ─────────────────────────
# Get a FREE key at https://aistudio.google.com/apikey — no billing needed.
# Free tier: ~15 RPM for Flash, ~1500 requests/day. Much more generous
# than OpenRouter's free tier, perfect for hitting 4 agents per run.
#
# NOTE: Google AI Pro / Google One AI Premium is a SEPARATE product and
# does NOT include API access. You need a Google AI Studio key.
GOOGLE_API_KEY=

# ─── Provider + model choice ───────────────────────────────────────────
# LLM_PROVIDER: "anthropic", "openai", or "google"
LLM_PROVIDER=google
LLM_MODEL=gemini-2.0-flash

# ─── Per-agent model overrides (optional) ──────────────────────────────
# Route cheap agents to Flash, smart agents to Pro. Leave blank to use
# LLM_MODEL above for everything.
#
# Recommended Gemini split (dodges free-tier rate limits):
#   LLM_MODEL_NEWS=gemini-2.0-flash
#   LLM_MODEL_SENTIMENT=gemini-2.0-flash
#   LLM_MODEL_ANALYST=gemini-2.0-flash     # or gemini-2.5-pro if you have quota
#   LLM_MODEL_REPORT=gemini-2.5-pro        # smarter reasoning for the final brief
LLM_MODEL_NEWS=
LLM_MODEL_SENTIMENT=
LLM_MODEL_ANALYST=
LLM_MODEL_REPORT=

# ─── Budget controls ───────────────────────────────────────────────────
# LLM_MODE:
#   "multi"  — each of the 4 agents makes its own LLM call (4 calls/ticker).
#              Highest quality, but can burst on parallel fan-out.
#   "single" — the 3 data agents skip their LLM and only fetch data.
#              The Report Writer is then the SOLE LLM call per ticker,
#              working directly from the raw news items / Reddit posts /
#              fundamentals. Best for tight free-tier quotas — one call
#              per ticker means you can run AAPL, MSFT, TSLA, NVDA, GOOG,
#              META, AMZN, ... in a single minute under a 10 RPM cap.
LLM_MODE=single

# Global cap on LLM requests per minute across all agents (0 = disabled).
# Gemini Flash free tier is ~10 RPM; default 8 leaves headroom.
# Any burst above this cap will be smoothed with sleep()s.
LLM_RPM_LIMIT=8

# ─── OpenAI-compatible base URL override ───────────────────────────────
# Leave blank for real OpenAI. Set to use OpenRouter, Together, Groq, Ollama.
#
# OpenRouter example:
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=sk-or-v1-your-openrouter-key
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
#
# Other free OpenRouter models (slugs rotate — check openrouter.ai/models?max_price=0):
#   google/gemini-2.0-flash-exp:free
#   qwen/qwen-2.5-72b-instruct:free
#   deepseek/deepseek-chat:free
OPENAI_BASE_URL=

# ─── Other settings ────────────────────────────────────────────────────
# SEC EDGAR requires a contact user-agent per their fair-access policy
SEC_USER_AGENT=Your Name your-email@example.com

# Tune behavior
CACHE_TTL_SECONDS=3600
MAX_NEWS_ITEMS=20
MAX_REDDIT_POSTS=25
